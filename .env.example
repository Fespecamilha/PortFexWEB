# Portfex Web — Variáveis de Ambiente
# Configure no Render: Settings → Environment Variables

# Obrigatórias
SECRET_KEY=gere-com-python-secrets-token-hex-32
JWT_SECRET=outra-chave-aleatoria-diferente
DATABASE_URL=postgresql://...  (Render PostgreSQL gera automaticamente)

# Kiwify (pagamentos)
KIWIFY_SECRET=webhook-secret-do-kiwify

# URL do app
APP_URL=https://portfex.onrender.com

# Python version
PYTHON_VERSION=3.11.9
